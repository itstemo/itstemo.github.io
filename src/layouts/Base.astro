---
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/newsreader';
import '@fontsource-variable/newsreader/wght-italic.css';
import '../styles/global.css';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  wordmark?: boolean;
  lang?: Lang;
  /** Path to this same page in the other locale, e.g. "/es/about" from "/about". */
  altLangHref: string;
}

const { title, description, wordmark = true, lang = 'en', altLangHref } = Astro.props;

const t = useTranslations(lang);
const pageDescription = description ?? t('meta.description');
const otherLang = lang === 'en' ? 'es' : 'en';
const enHref = lang === 'en' ? Astro.url.pathname : altLangHref;
const esHref = lang === 'es' ? Astro.url.pathname : altLangHref;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href={new URL(enHref, Astro.site)} />
    <link rel="alternate" hreflang="es" href={new URL(esHref, Astro.site)} />
    <title>{title}</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') {
        document.documentElement.dataset.theme = stored;
      }
    </script>
    {
      lang === 'en' && (
        <script is:inline define:vars={{ altLangHref }}>
          if (!localStorage.getItem('lang')) {
            const browserLang = navigator.language || '';
            if (browserLang.toLowerCase().startsWith('es')) {
              localStorage.setItem('lang', 'es');
              location.replace(altLangHref);
            }
          }
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      {
        wordmark && (
          <a href="/" class="link wordmark">
            Temo <em>Ojeda</em>
          </a>
        )
      }
      <div class="header-right">
        <nav>
          <a href={lang === 'en' ? '/blog' : '/es/blog'} class="link">{t('nav.blog')}</a>
          <a href={lang === 'en' ? '/about' : '/es/about'} class="link">{t('nav.about')}</a>
          <a href={lang === 'en' ? '/contact' : '/es/contact'} class="link">{t('nav.contact')}</a>
        </nav>
        <a
          href={altLangHref}
          class="lang-toggle"
          aria-label={`Switch to ${otherLang === 'es' ? 'Spanish' : 'English'}`}
          onclick={`localStorage.setItem('lang', '${otherLang}')`}
        >
          {lang.toUpperCase()}
        </a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <svg
        class="icon-moon"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg
        class="icon-sun"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
        </button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      let themeTransitionTimer;
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const root = document.documentElement;
        const systemDark = matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = root.dataset.theme ? root.dataset.theme === 'dark' : systemDark;
        const next = isDark ? 'light' : 'dark';
        root.classList.add('theme-transition');
        clearTimeout(themeTransitionTimer);
        themeTransitionTimer = setTimeout(() => root.classList.remove('theme-transition'), 500);
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
