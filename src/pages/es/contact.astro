---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
---

<Base title="Contacto — Temo Ojeda" lang="es" altLangHref="/contact">
  <h1 class="page-title">{t('contact.title')}</h1>
  <div class="prose">
    <p>{t('contact.intro')}</p>
    <ul class="channels">
      <li>
        <span class="meta">GitHub</span>
        <a href="https://github.com/itstemo" class="link">github.com/itstemo</a>
      </li>
      <li>
        <span class="meta">X</span>
        <a href="https://x.com/itstemo" class="link">@itstemo</a>
      </li>
    </ul>
  </div>
</Base>

<style>
  .page-title {
    margin: 0 0 3rem;
    font-size: 3rem;
  }

  .channels {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .channels li {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .channels .meta {
    min-width: 4.5rem;
  }
</style>
