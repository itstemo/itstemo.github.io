---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('es');

const posts = (
  await getCollection('blog', ({ id, data }) => id.startsWith('es/') && !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<Base title="Blog — Temo Ojeda" lang="es" altLangHref="/blog">
  <h1 class="page-title">{t('blog.title')}</h1>
  <ul class="posts">
    {
      posts.map((post) => (
        <li>
          <p class="meta">{formatDate(post.data.date)}</p>
          <a href={`/es/blog/${post.id.slice(3)}/`} class="link post-title">
            {post.data.title}
          </a>
          {post.data.description && <p class="description">{post.data.description}</p>}
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .page-title {
    margin: 0 0 3rem;
    font-size: 3rem;
  }

  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .posts li {
    margin-bottom: 2.5rem;
  }

  .posts .meta {
    margin: 0 0 0.375rem;
  }

  .post-title {
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }

  .description {
    margin: 0.5rem 0 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--body);
    max-width: 34rem;
  }
</style>
