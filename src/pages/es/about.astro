---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
---

<Base title="Acerca — Temo Ojeda" lang="es" altLangHref="/about">
  <h1 class="page-title">{t('about.title')}</h1>
  <div class="prose">
    <p>{t('about.p1')}</p>
    <p>{t('about.p2')}</p>
  </div>
</Base>

<style>
  .page-title {
    margin: 0 0 3rem;
    font-size: 3rem;
  }
</style>
