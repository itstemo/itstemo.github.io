---
import Base from '../layouts/Base.astro';
---

<Base title="Temo Ojeda" header={false}>
  <section class="hero">
    <div class="title">
      <h1 class="name">Temo<br /><em>Ojeda</em></h1>
      <p class="tagline">Data, software, and agaves.</p>
    </div>
    <nav class="hero-nav">
      <a href="/blog" class="link">Blog</a>
      <a href="/about" class="link">About</a>
      <a href="/contact" class="link">Contact</a>
    </nav>
  </section>
</Base>

<style>
  .hero {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .title {
    margin: auto 0;
  }

  .name {
    margin: 0;
    font-size: clamp(4rem, 10vw, 8.5rem);
    letter-spacing: -0.01em;
    line-height: 0.95;
  }

  .tagline {
    margin: 1.75rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1875rem;
    color: var(--muted);
  }

  .hero-nav {
    display: flex;
    gap: 2.5rem;
    margin-top: 2.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
</style>
