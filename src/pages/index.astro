---
import Base from '../layouts/Base.astro';
---

<Base title="Temo Ojeda" header={false}>
  <section class="hero">
    <h1 class="name">Temo<br /><em>Ojeda</em></h1>
    <p class="tagline">Data, software, and agaves.</p>
    <nav class="hero-nav">
      <a href="/blog" class="link">Blog</a>
      <a href="/about" class="link">About</a>
      <a href="/contact" class="link">Contact</a>
    </nav>
  </section>
</Base>

<style>
  .hero {
    margin: auto 0;
    padding: 4rem 0;
  }

  .name {
    margin: 0;
    font-size: clamp(4.5rem, 15vw, 8rem);
    letter-spacing: -0.01em;
    line-height: 0.95;
  }

  .tagline {
    margin: 1.75rem 0 0;
    font-size: 1.0625rem;
    color: var(--muted);
  }

  .hero-nav {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
  }
</style>
